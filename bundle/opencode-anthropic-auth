function ensureParent(path) {
  mkdirSync(dirname(path), { recursive: true });
}

function loadAuth() {
  ensureParent(AUTH_PATH);
  if (!existsSync(AUTH_PATH)) {
    return {};
  }
  return JSON.parse(readFileSync(AUTH_PATH, "utf8"));
}

function backupAuth() {
  if (existsSync(AUTH_PATH) && !existsSync(BACKUP_PATH)) {
    ensureParent(BACKUP_PATH);
    copyFileSync(AUTH_PATH, BACKUP_PATH);
  }
}

function saveAuth(auth) {
  backupAuth();
  ensureParent(AUTH_PATH);
  writeFileSync(AUTH_PATH, JSON.stringify(auth, null, 2) + "\n");
}

function writeJsonAtomic(path, value, mode = 0o600) {
  ensureParent(path);
  const temporaryPath = `${path}.tmp-${process.pid}-${Date.now()}`;
  writeFileSync(temporaryPath, JSON.stringify(value, null, 2) + "\n", { mode });
  chmodSync(temporaryPath, mode);
  renameSync(temporaryPath, path);
  chmodSync(path, mode);
}

function normalizePluginConfig(rawConfig) {
  const schemaVersion = rawConfig?.schemaVersion === DEFAULT_PLUGIN_CONFIG.schemaVersion
    ? rawConfig.schemaVersion
    : DEFAULT_PLUGIN_CONFIG.schemaVersion;
  const betaHeaders = Array.isArray(rawConfig?.betaHeaders)
    ? rawConfig.betaHeaders
      .filter((value) => typeof value === "string")
      .map((value) => value.trim())
      .filter(Boolean)
    : DEFAULT_PLUGIN_CONFIG.betaHeaders;
  const userAgent = typeof rawConfig?.userAgent === "string" && rawConfig.userAgent.trim()
    ? rawConfig.userAgent.trim()
    : DEFAULT_PLUGIN_CONFIG.userAgent;

  return {
    schemaVersion,
    betaHeaders,
    userAgent,
  };
}

function loadPluginConfig() {
  ensureParent(PLUGIN_CONFIG_PATH);
  if (!existsSync(PLUGIN_CONFIG_PATH)) {
    return normalizePluginConfig({});
  }
  return normalizePluginConfig(JSON.parse(readFileSync(PLUGIN_CONFIG_PATH, "utf8")));
}

function savePluginConfig(config) {
  writeJsonAtomic(PLUGIN_CONFIG_PATH, normalizePluginConfig(config));
}

function parseBetaHeaders(input) {
  if (!input) {
    throw new Error("Provide beta headers as comma-separated values or 'none'.");
  }

  if (input === "none") {
    return [];
  }

  const betaHeaders = input
    .split(",")
    .map((value) => value.trim())
    .filter(Boolean);

  if (betaHeaders.length === 0) {
    throw new Error("No valid beta headers were provided.");
  }

  return betaHeaders;
}

function printPluginConfig() {
  const config = loadPluginConfig();
  console.log(`Plugin config: ${PLUGIN_CONFIG_PATH}`);
  console.log(`Schema version: ${config.schemaVersion}`);
  console.log(`Beta headers: ${config.betaHeaders.length ? config.betaHeaders.join(", ") : "(none)"}`);
  console.log(`User-Agent: ${config.userAgent}`);
}

function setPluginBetas(input) {
  const config = loadPluginConfig();
  config.betaHeaders = parseBetaHeaders(input);
  savePluginConfig(config);
  printPluginConfig();
}

function setPluginUserAgent(input) {
  if (!input) {
    throw new Error("Provide a user-agent string or 'default'.");
  }

  const config = loadPluginConfig();
  config.userAgent = input === "default" ? DEFAULT_PLUGIN_CONFIG.userAgent : input.trim();
  if (!config.userAgent) {
    throw new Error("User-Agent cannot be empty.");
  }
  savePluginConfig(config);
  printPluginConfig();
}

function resetPluginConfig() {
  savePluginConfig(DEFAULT_PLUGIN_CONFIG);
  printPluginConfig();
}

